{
  "name": "action-setup-workspace",
  "description": "Reusable composite GitHub Action to set up the dnd-mapp Node.js/Pnpm workspace",
  "version": "2.0.0",
  "private": true,
  "license": "MIT",
  "author": "NoNamer777",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dnd-mapp/action-setup-workspace.git"
  },
  "homepage": "https://github.com/dnd-mapp/action-setup-workspace#readme",
  "bugs": "https://github.com/dnd-mapp/action-setup-workspace/issues",
  "scripts": {
    "prepare": "husky || true",
    "lint-md": "markdownlint-cli2 \"**/*.md\"",
    "format": "prettier -w .",
    "format-check": "prettier -l ."
  },
  "engines": {
    "node": ">=24.18.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.13.1",
      "onFail": "error"
    }
  },
  "type": "module",
  "devDependencies": {
    "@commitlint/cli": "~21.2.1",
    "@commitlint/config-conventional": "~21.2.0",
    "@types/node": "~24.13.3",
    "husky": "~9.1.7",
    "lint-staged": "~17.0.8",
    "markdownlint-cli2": "~0.23.0",
    "prettier": "~3.9.5",
    "prettier-plugin-organize-imports": "~4.3.0"
  }
}
